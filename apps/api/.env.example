API_HOST=0.0.0.0
API_PORT=8000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

OPENAI_API_KEY=your-openai-key
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
OPENAI_PARSE_MODEL=gpt-4.1-mini
OPENAI_VISION_MODEL=gpt-4.1-mini
ENABLE_FRAME_OCR=1

APIFY_TOKEN=your-apify-token

# ─── Creator corpus (Jacob TikTok knowledge base) ───────────────────────────
# Master toggle for the /admin/corpus/* endpoints. Without this set to "1"
# every admin-corpus route returns 503, so deploying this code without
# flipping it on cannot accidentally expose admin actions.
CORPUS_ADMIN_ENABLED=1
# OpenAI embedding model used for content_embeddings. Must match the
# `vector(N)` column dimensionality in 011_creator_corpus.sql (1536 today).
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Synthesis model used by /chat. Defaults to gpt-4.1-mini (cheap and good
# for short coaching answers). Bump to a larger model when you want richer
# voice or longer responses.
# OPENAI_CHAT_MODEL=gpt-4.1-mini

APPLE_APP_BUNDLE_ID=com.fitfo.mobile

# ─── Apple Sign In refresh-token revocation (App Store 5.1.1(v)) ─────────────
# Required for DELETE /auth/me to revoke Sign-in-with-Apple refresh tokens.
# Without these, account deletion still works locally but Apple won't be told
# to unlink the app from the user's Apple ID.
# APPLE_TEAM_ID=XXXXXXXXXX
# APPLE_SIGNIN_KEY_ID=XXXXXXXXXX
# APPLE_SIGNIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIGT...\n-----END PRIVATE KEY-----"

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_SERVICE_SID=your-twilio-verify-service-sid
TWILIO_VERIFY_FRIENDLY_NAME=Fitfo
# ISO 3166-1 alpha-2 region for national-format phone input (numbers without +country).
# Matches typical Twilio Verify usage for E.164. Example for UK-first traffic: GB
PHONE_DEFAULT_REGION=US

APP_JWT_SECRET=replace-with-a-long-random-secret
APP_JWT_EXPIRES_IN_SECONDS=2592000

# ─── Apple App Review demo account ──────────────────────────────────────────
# When set, any /auth/send-otp and /auth/verify-otp request from this phone
# skips Twilio and uses REVIEWER_OTP_CODE directly. Put these credentials in
# App Store Connect → App Information → App Review Information → Demo Account.
# Leave empty in dev / production-facing environments so no one can bypass SMS.
# REVIEWER_PHONE=+15555551234
# REVIEWER_OTP_CODE=424242

# ─── Fitfo Pro server bypass (team / founders) ───────────────────────────────
# Profiles matching these values receive fitfo_pro_bypass: true from /auth/*
# so the app treats them as Pro without RevenueCat. Use comma, newline, or
# semicolon between multiple accounts (e.g. several emails or user UUIDs).
# There is no in-code allowlist — set these env vars for any team accounts.
# FITFO_PRO_BYPASS_USER_IDS=uuid-one,uuid-two
# FITFO_PRO_BYPASS_EMAILS=you@company.com,cofounder@company.com
# FITFO_PRO_BYPASS_PHONES=+15551234567,+15559876543
# To list existing profiles in Supabase: sql/queries/list_profiles_for_billing.sql

# ─── Expo push (lifecycle + import-complete notifications) ──────────────────
# Optional. Higher rate limits / team sends: https://expo.dev/accounts/[account]/settings/access-tokens
# EXPO_ACCESS_TOKEN=
# Set to 1 to skip calling Expo while debugging.
# DISABLE_EXPO_PUSH=0

# ─── RevenueCat webhook (trial lifecycle / conversion pushes) ───────────────
# Required for the 48h pre-charge reminder + post-trial conversion push.
# Generate any random string (e.g. `openssl rand -hex 32`), then paste the
# SAME value into:
#   1. RevenueCat dashboard → Project → Apps → FitFo → Webhook URL
#      → "Authorization header value"
#   2. Webhook URL itself: https://<your-api-host>/webhooks/revenuecat
# REVENUECAT_WEBHOOK_AUTH_TOKEN=
