# Public base URL with scheme (canonical site). Used for OG URLs, canonicals, `/app`.
# NEXT_PUBLIC_SITE_URL=https://www.fitfo.app

# Optional override — defaults match layout metadata (`id6762418380`).
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/us/app/id6762418380

# Optional — enables timed fallback on `/app` for Android users toward Play listing.
# NEXT_PUBLIC_PLAY_STORE_URL=

# Overrides default Team ID baked into /.well-known/apple-app-site-association (normally not needed).
# APPLE_TEAM_ID=533W5X82G7

# --- Internal app health (/admin/dashboard): PostHog + Shot embeds & shortcuts ---
# NEXT_PUBLIC_APP_HEALTH_DASHBOARD_ENABLED=1
# PostHog: open a dashboard → Share → embed URL (HTTPS host must be *.posthog.com).
# NEXT_PUBLIC_POSTHOG_DASHBOARD_EMBED_URL=
# Project home for the “Open” button and quick link (EU or US).
# NEXT_PUBLIC_POSTHOG_PROJECT_URL=https://eu.posthog.com/project/YOUR_NUMERIC_ID

# Shot: HTTPS embed if your tool supports iframes; otherwise link-only below.
# NEXT_PUBLIC_SHOT_DASHBOARD_EMBED_URL=
# NEXT_PUBLIC_SHOT_DASHBOARD_URL=

# Optional Expo deep link (EAS builds).
# NEXT_PUBLIC_EXPO_PROJECT_URL=https://expo.dev/accounts/YOUR_ACCOUNT/projects/fitfo-mobile
